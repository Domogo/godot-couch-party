; Engine configuration file.
; This project exists to run the addon test and example suites.

config_version=5

[application]

config/name="Godot Couch Party"
run/main_scene="res://examples/demo.tscn"
config/features=PackedStringArray("4.7")

[debug]

gdscript/warnings/enable=true
gdscript/warnings/untyped_declaration=2
gdscript/warnings/integer_division=2
gdscript/warnings/shadowed_global_identifier=2
gdscript/warnings/incompatible_ternary=2

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
